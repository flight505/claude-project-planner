# =============================================================================
# CLAUDE CODE AUTHENTICATION
# =============================================================================
# Choose ONE of the following based on your subscription:

# Option 1: Claude Max subscribers (OAuth - handled automatically by Claude Code)
# No API key needed! Just run `claude` and authenticate via browser.

# Option 2: API users (direct API access)
# ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# =============================================================================
# PLUGIN SERVICES (Optional - for enhanced features)
# =============================================================================

# OpenRouter API key (for research-lookup skill)
# Get your key at: https://openrouter.ai/keys
# Enables: Real-time web search, academic paper lookup via Perplexity Sonar Pro
OPENROUTER_API_KEY=sk-or-v1-...your-key-here...

# Google Gemini API key (for Deep Research and image/video generation)
# Get your key at: https://ai.google.dev/
# Enables: Deep Research (~60 min comprehensive analysis), Imagen 4, Veo 3.1 video
GEMINI_API_KEY=AIza...your-key-here...
